# Copy to .env and fill in values as needed.
# cp .env.example .env

# Chain build target: prod = TT Chain mainnet (1679); test or unset = testnet (167901)
REACT_APP_CHAIN=test

# Production-like behavior when set to prod or production
# REACT_APP_ENV=prod

# WalletConnect Cloud project ID — required for WalletConnect wallet connections
# https://cloud.walletconnect.com
REACT_APP_WALLETCONNECT_PROJECT_ID=

# Optional Ankr API key for higher-rate-limit RPC fallback endpoints
# REACT_APP_ANKR_API_KEY=

# Infura API key — used by Hardhat fork tests only (hardhat.config.js)
# REACT_APP_INFURA_KEY=

# Cypress Dashboard project ID — optional, only needed for Cypress Cloud recording
# CYPRESS_PROJECT_ID=

# Optional: shown on the settings page
# REACT_APP_GIT_COMMIT_HASH=

# Set to false to disable the service worker
# REACT_APP_SERVICE_WORKER=false
